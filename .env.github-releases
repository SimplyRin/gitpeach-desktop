# GitHub Desktop Update Configuration

# Set this to 'true' to enable updates from GitHub Releases instead of central.github.com
USE_GITHUB_RELEASES=true

# Configure the GitHub repository for releases
# Default: SimplyRin/desktop
GITHUB_RELEASES_OWNER=SimplyRin
GITHUB_RELEASES_REPO=desktop

# Optional: OAuth configuration for GitHub API (if needed for private repos)
# GITHUB_RELEASES_TOKEN=your_github_token_here
